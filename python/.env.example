SECRET_KEY=dev-change-me-in-production
DEBUG=True
SITE_URL=http://127.0.0.1:8000
# Comma-separated hosts (Render host is auto-added via RENDER_EXTERNAL_HOSTNAME)
ALLOWED_HOSTS=localhost,127.0.0.1
# Required in production for POST forms/webhooks, e.g. https://yourapp.onrender.com
CSRF_TRUSTED_ORIGINS=

# PostgreSQL (start with: docker compose up -d)
DATABASE_URL=postgres://rentagentgh:rentagentgh@localhost:5433/rentagentgh

# Paystack — https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CURRENCY=GHS
# Fee (GHS) a renter pays to unlock contacting an agent. Set 0 to make it free.
CONTACT_UNLOCK_AMOUNT_GHS=5

# Arkesel SMS — https://sms.arkesel.com (API key from dashboard)
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=RentAgent
# Set to False to log SMS to console instead of sending (even if API key is set)
SMS_ENABLED=False
# Minutes between SMS alerts for the same conversation (follow-up messages)
AGENT_SMS_COOLDOWN_MINUTES=15
